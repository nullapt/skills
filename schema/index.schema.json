{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NullApt Skill Index Entry",
  "type": "object",
  "required": ["name", "version", "description", "author", "homepage", "license", "registry_url", "tags", "permissions_summary"],
  "additionalProperties": false,
  "properties": {
    "name":         { "type": "string", "pattern": "^[a-z0-9][a-z0-9_\\-]*(/[a-z0-9][a-z0-9_\\-]*)?$" },
    "version":      { "type": "string" },
    "description":  { "type": "string", "maxLength": 200 },
    "author":       { "type": "string" },
    "homepage":     { "type": "string", "format": "uri" },
    "license":      { "type": "string" },
    "registry_url": { "type": "string", "format": "uri" },
    "tags":         { "type": "array", "items": { "type": "string" }, "maxItems": 10 },
    "permissions_summary": {
      "type": "object",
      "required": ["network", "filesystem", "env"],
      "properties": {
        "network":         { "type": "boolean" },
        "network_domains": { "type": "array", "items": { "type": "string" } },
        "filesystem":      { "type": "boolean" },
        "filesystem_paths":{ "type": "array", "items": { "type": "string" } },
        "env":             { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
